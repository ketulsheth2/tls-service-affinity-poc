+/* service-affinity PoC: emit a migrate_request post-handshake message (type
+ * 0xFD) into sendbuf. Body is uint16 target_len followed by the target. */
+int ptls_svcaff_send_migrate_request(ptls_t *tls, ptls_buffer_t *sendbuf, const char *target)
+{
+    struct st_ptls_record_message_emitter_t emitter;
+    int ret;
+    size_t tlen = target != NULL ? strlen(target) : 0;
+
+    init_record_message_emitter(tls, &emitter, sendbuf);
+    size_t orig_off = emitter.super.buf->off;
+
+    ptls_push_message(&emitter.super, NULL, 0xFD, {
+        ptls_buffer_push16(emitter.super.buf, (uint16_t)tlen);
+        ptls_buffer_pushv(emitter.super.buf, target, tlen);
+    });
+    ret = 0;
+
+Exit:
+    if (ret != 0)
+        emitter.super.buf->off = orig_off;
+    return ret;
+}
